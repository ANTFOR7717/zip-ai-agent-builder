  "is_long_running": false,
  "exported_at": "2026-02-19T11:45:00.000Z",
  "config_pages": [
    {
      "title": "Connections",
      "description": "Configure connections for notifications and data storage.",
      "items": [
        { "kind": "config_var", "config_var_key": "http_connection" }
      ]
    },
    { "title": "Setup", "description": "", "items": [] }
  ],
  "config_vars": {
    "http_connection": {
      "key": "http_connection",
      "title": "HTTP Connection",
      "description": "Used for Zip comments and risk storage.",
      "required": true,
      "kind": "connection",
      "connector": { "key": "http" }
    }
  },
  "flow_config_pages": [],
  "flow_config_vars": {},
  "steps_data": [
    {
      "key": "trigger",
      "display_name": "Approval assist",
      "connector_key": "ai",
      "action_key": "approval_assist",
      "input_config": null,
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "zip_1",
      "display_name": "Get request",
      "connector_key": "zip",
      "action_key": "get_request",
      "input_config": {
        "control": "object",
        "value": {
          "request_id": { "control": "text", "value": "${steps.trigger.request.id}" }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "ai_1",
      "display_name": "Document Check",
      "connector_key": "ai",
      "action_key": "generic_ai",
      "input_config": {
        "control": "object",
        "value": {
          "user_prompt": {
            "control": "text",
            "value": "Objective: Act as a Document Verification Agent.\n\nContext: Review the documents associated with Zip Request ID ${steps.zip_1.id}.\n\nTask: Identify if there is a contract, MSA, SOW, or Order Form attached.\n\nOutput Format: Structured JSON with document_found (boolean) and document_name (string)."
          },
          "tools": { "control": "multipicklist", "value": ["document"] },
          "output_format": { "control": "picklist", "value": "structured" },
          "structured_schema": {
            "control": "array",
            "value": [
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "document_found" },
                  "description": { "control": "text", "value": "True if a relevant contract document is found" },
                  "type": { "control": "picklist", "value": "boolean" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "document_name" },
                  "description": { "control": "text", "value": "Name of the detected document" },
                  "type": { "control": "picklist", "value": "string" }
                }
              }
            ]
          }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "ai_2",
      "display_name": "Contract Extraction",
      "connector_key": "ai",
      "action_key": "generic_ai",
      "input_config": {
        "control": "object",
        "value": {
          "user_prompt": {
            "control": "text",
            "value": "Objective: Act as a specialized Financial Contract Extraction Agent.\n\nContext: Review the documents associated with Zip Request ID ${steps.zip_1.id}.\n\nInstructions:\n1. Source Identification: Prioritize MSA, then SOW, then Order Form.\n2. Core Commercials: Extract Vendor Name, Effective Date, Expiration Date, Total Contract Value, and Payment Terms.\n3. Financial Units: Extract License Counts (Total/Committed), Usage Limits (API calls, Storage, etc.), and Draw-down/Pre-payment schedules.\n4. Price Tiers: Identify specific unit price breaks based on volume or licenses.\n\nConstraints: Do not guess; return null if a value is absent."
          },
          "tools": { "control": "multipicklist", "value": ["document", "zip_data"] },
          "output_format": { "control": "picklist", "value": "structured" },
          "structured_schema": {
            "control": "array",
            "value": [
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "vendor_name" },
                  "description": { "control": "text", "value": "Extracted vendor name" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "total_value" },
                  "description": { "control": "text", "value": "Total contract value" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "effective_date" },
                  "description": { "control": "text", "value": "Start date" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "expiration_date" },
                  "description": { "control": "text", "value": "End date" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "payment_terms" },
                  "description": { "control": "text", "value": "Net terms" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "license_counts" },
                  "description": { "control": "text", "value": "Total and committed license counts" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "usage_limits" },
                  "description": { "control": "text", "value": "Usage limits (e.g. API calls, Storage)" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "draw_down_schedule" },
                  "description": { "control": "text", "value": "Draw-down or pre-payment schedule" },
                  "type": { "control": "picklist", "value": "string" }
                }
              }
            ]
          }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "ai_3",
      "display_name": "Risk & Financial Analysis",
      "connector_key": "ai",
      "action_key": "generic_ai",
      "input_config": {
        "control": "object",
        "value": {
          "user_prompt": {
            "control": "text",
            "value": "Objective: Senior Finance & Procurement Analyst.\n\nTask: Evaluate financial liability and forecasting impact from ${steps.ai_2.response}.\n\nInstructions:\n1. Forecasting Risk: Analyze 'Draw-down' and 'Overage Rates'.\n2. License Impact: Identify 'True-up' frequency.\n3. Commercial Triggers: Flag 'Price Escalators' (CPI).\n4. Risk Scoring: Flag as High Risk if auto-renewal notice < 60 days or overage penalties > 10%."
          },
          "output_format": { "control": "picklist", "value": "structured" },
          "structured_schema": {
            "control": "array",
            "value": [
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "high_risk_found" },
                  "description": { "control": "text", "value": "Boolean flag for critical risk" },
                  "type": { "control": "picklist", "value": "boolean" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "risk_summary" },
                  "description": { "control": "text", "value": "Summary of identified risks" },
                  "type": { "control": "picklist", "value": "string" }
                }
              },
              {
                "control": "object",
                "value": {
                  "key": { "control": "text", "value": "true_ups" },
                  "description": { "control": "text", "value": "True-up and tier logic" },
                  "type": { "control": "picklist", "value": "string" }
                }
              }
            ]
          }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "ai_4",
      "display_name": "Markdown Report Generation",
      "connector_key": "ai",
      "action_key": "generic_ai",
      "input_config": {
        "control": "object",
        "value": {
          "user_prompt": {
            "control": "text",
            "value": "Objective: Act as a Senior Finance Analyst generating a structured contract review.\n\nPrompt Instructions:\n1. Summary Banner:\n   - Title: If ${steps.ai_3.response.high_risk_found} is true, output \"Financial Risk: Action Required\". Otherwise, \"Contract Terms Validated\".\n   - Subtitle: Write a 1-sentence summary of the primary forecasting impact.\n2. Executive Summary:\n   - Heading: \"# Executive Summary\"\n   - Content: Provide a 2-3 sentence overview of the commercial health. Mention total value ${steps.ai_2.response.total_value}.\n3. Risk Scorecard Table:\n   - Heading: \"## Financial Risk Assessment\"\n   - Description: \"The following areas impact budget forecasting and commercial liability.\"\n   - Markdown Table (4 Columns): |   | Risk Area | Findings | Recommendation |\n   - Column 1 (Icon): Use \"Red icon\" for High Risk, \"Yellow icon\" for Medium Risk, \"Green icon\" for Low/Standard.\n   - Column 2 (Risk Area): (e.g., Usage Overages, License True-ups, Price Escalation, Draw-down Logic).\n   - Column 3 (Findings): Specific detail extracted in ai_3.\n   - Column 4 (Recommendation): Mitigation step for finance partners.\n4. Key Commercial Terms Detail:\n   - Heading: \"## Key Commercial Terms\"\n   - Simple 2-column table for: Vendor, Effective Date, Expiration Date, Net Terms, and Governing Law.\n\nConstraints: No conversational filler. Ensure icons are written as \"Red icon\", etc."
          },
          "output_format": { "control": "picklist", "value": "markdown" }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "ai_5",
      "display_name": "No Document Error",
      "connector_key": "ai",
      "action_key": "generic_ai",
      "input_config": {
        "control": "object",
        "value": {
          "user_prompt": {
            "control": "text",
            "value": "Summary banner\nRed\nTitle: No Contract Document Found\nSubtitle: Please upload an MSA, SOW, or Order Form to proceed with the financial review."
          },
          "output_format": { "control": "picklist", "value": "markdown" }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "condition_1",
      "display_name": "Document Presence Check",
      "connector_key": "condition",
      "action_key": "if_condition",
      "input_config": {
        "control": "object",
        "value": {
          "conditions": {
            "control": "array",
            "value": [
              {
                "control": "object",
                "value": {
                  "left_value": { "control": "ref", "value": "steps.ai_1.response.document_found" },
                  "operator": { "control": "picklist", "value": "equals" },
                  "right_value": { "control": "boolean", "value": true }
                }
              }
            ]
          }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "condition_2",
      "display_name": "High Risk Check",
      "connector_key": "condition",
      "action_key": "if_condition",
      "input_config": {
        "control": "object",
        "value": {
          "conditions": {
            "control": "array",
            "value": [
              {
                "control": "object",
                "value": {
                  "left_value": { "control": "ref", "value": "steps.ai_3.response.high_risk_found" },
                  "operator": { "control": "picklist", "value": "equals" },
                  "right_value": { "control": "boolean", "value": true }
                }
              }
            ]
          }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": null
    },
    {
      "key": "http_1",
      "display_name": "Finance Notification",
      "connector_key": "http",
      "action_key": "$http_client",
      "input_config": {
        "control": "object",
        "value": {
          "method": { "control": "picklist", "value": "POST" },
          "url": { "control": "text", "value": "/comments" },
          "request_body": {
            "control": "text",
            "value": "{\n  \"data\": {\n    \"text\": \"@finance-team HIGH RISK contract detected for ${steps.ai_2.response.vendor_name}. Please review request ${steps.trigger.request.id}.\",\n    \"external_display_name\": \"Contract Review Bot\",\n    \"purchase_requisition_id\": \"${steps.trigger.request.id}\"\n  }\n}"
          },
          "content_type": { "control": "picklist", "value": "application/json" }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": "config.http_connection"
    },
    {
      "key": "http_2",
      "display_name": "Risk Repository Storage",
      "connector_key": "http",
      "action_key": "$http_client",
      "input_config": {
        "control": "object",
        "value": {
          "method": { "control": "picklist", "value": "POST" },
          "url": { "control": "text", "value": "/contract_risks" },
          "request_body": {
            "control": "text",
            "value": "{\n  \"data\": {\n    \"request_id\": \"${steps.trigger.request.id}\",\n    \"vendor\": \"${steps.ai_2.response.vendor_name}\",\n    \"risk_summary\": \"${steps.ai_3.response.risk_summary}\",\n    \"true_up_logic\": \"${steps.ai_3.response.true_ups}\"\n  }\n}"
          },
          "content_type": { "control": "picklist", "value": "application/json" }
        }
      },
      "branches": null,
      "error_handling_policy": 1,
      "connection_var_key": "config.http_connection"
    },
    {
      "key": "return_1",
